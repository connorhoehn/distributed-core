{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "../dist-bench",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": true
  },
  "include": [
    "../benchmarks/**/*",
    "../src/**/*"
  ],
  "exclude": [
    "../node_modules",
    "../dist",
    "../dist-bench",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
