{
  "name": "distributed-core",
  "version": "1.0.0",
  "description": "Core library for distributed score system with gossip protocol, transport, and state management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./applications/pipeline": {
      "types": "./dist/applications/pipeline/index.d.ts",
      "default": "./dist/applications/pipeline/index.js"
    },
    "./gateway": {
      "types": "./dist/gateway/index.d.ts",
      "default": "./dist/gateway/index.js"
    },
    "./routing": {
      "types": "./dist/routing/index.d.ts",
      "default": "./dist/routing/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:e2e:cluster": "jest --config jest.e2e.config.js test/e2e/cluster/",
    "test:e2e:persistence": "jest --config jest.e2e.config.js test/e2e/persistence/",
    "test:e2e:transport": "jest --config jest.e2e.config.js test/e2e/transport/",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "bench": "npx ts-node benchmarks/run-all.ts",
    "bench:one": "npx ts-node"
  },
  "keywords": [
    "distributed",
    "gossip",
    "p2p",
    "state-management",
    "transport"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^18.19.120",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "benchmark": "^2.1.4",
    "eslint": "^8.37.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.13.4",
    "eventemitter3": "^5.0.0",
    "js-yaml": "^4.1.0",
    "lz4": "^0.6.5",
    "ws": "^8.18.3",
    "zstd-codec": "^0.1.5"
  },
  "bin": {
    "dcore": "./bin/dcore.js"
  },
  "files": [
    "dist/**/*",
    "bin/*",
    "README.md",
    "LICENSE"
  ]
}
