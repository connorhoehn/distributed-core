{
  "name": "distributed-core",
  "version": "1.0.0",
  "description": "Core library for distributed score system with gossip protocol, transport, and state management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "distributed-core": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:e2e:chat": "jest --config jest.e2e.config.js test/e2e/chat/",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "release": "npm run build && npm run test && npm version patch",
    "start": "ts-node src/cli/index.ts",
    "example:basic": "ts-node examples/basic-cluster/index.ts",
    "example:counter": "ts-node examples/distributed-counter/index.ts",
    "example:chat": "ts-node examples/chat-room/index.ts",
    "bench:wal": "ts-node --project benchmarks/tsconfig.json benchmarks/wal-throughput.ts",
    "bench:resources": "ts-node --project benchmarks/tsconfig.json benchmarks/resource-ops.ts",
    "bench:cluster": "ts-node --project benchmarks/tsconfig.json benchmarks/cluster-formation.ts"
  },
  "keywords": [
    "distributed",
    "gossip",
    "p2p",
    "state-management",
    "transport"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^18.19.120",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "eslint": "^8.37.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "eventemitter3": "^5.0.0",
    "js-yaml": "^4.1.0",
    "lz4": "^0.6.5",
    "ws": "^8.18.3"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "type": "commonjs"
}
